# Supabase — REMOVED (migrated to Kysely + Neon). DATABASE_URL below is the
# only DB connection string required. Old SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY
# vars are unused but may remain in local .env for rollback purposes.

# Optional: CORS origins for production (comma-separated)
# ALLOWED_ORIGINS=https://your-app.vercel.app

# Better Auth
BETTER_AUTH_SECRET=           # openssl rand -hex 32
BETTER_AUTH_URL=              # https://weminal.pages.dev (or http://localhost:3000 for dev)
BETTER_AUTH_API_KEY=          # from dash.better-auth.com — used by @better-auth/infra dashboard
DATABASE_URL=                 # postgresql://postgres.xxx:pass@aws-0-xx.pooler.supabase.com:6543/postgres?pgbouncer=true
GITHUB_CLIENT_ID=             # GitHub OAuth App → client ID
GITHUB_CLIENT_SECRET=         # GitHub OAuth App → client secret

# Public URL of the app (used by Better Auth browser client)
NEXT_PUBLIC_APP_URL=

# MCP_API_KEY is now DEPRECATED — generate a personal wem_ key from /profile instead
# MCP_API_KEY=
